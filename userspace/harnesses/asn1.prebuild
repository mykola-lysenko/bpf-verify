#!/bin/bash
# Generate an ASN.1 decoder (rsapubkey grammar) into $GEN for the asn1 fuzzer.
set -euo pipefail
: "${GEN:?}" "${KSRC:?}"
cc -O2 -I"${KSRC}/include" -o "${GEN}/asn1_compiler" "${KSRC}/scripts/asn1_compiler.c"
"${GEN}/asn1_compiler" "${KSRC}/crypto/rsapubkey.asn1" \
	"${GEN}/rsapubkey.asn1.c" "${GEN}/rsapubkey.asn1.h"
